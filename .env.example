# =============================================================================
# .env.example — MODELE de fichier de variables d'environnement
# -----------------------------------------------------------------------------
# ROLE : montre quelles variables le projet attend, SANS contenir de vraie
# valeur sensible. On le COPIE en ".env" (qui, lui, est ignore par Git) et on
# y met ses propres valeurs. Ces variables sont lues au demarrage par
# pydantic-settings pour configurer le projet (chemins, parametres...).
#
# Mode d'emploi : copier ce fichier en ".env" puis adapter les valeurs.
# IMPORTANT (syntaxe .env) : on commente UNIQUEMENT avec # AU-DESSUS de chaque
# ligne CLE=valeur. On ne met JAMAIS de commentaire en fin de ligne apres la
# valeur, car certaines librairies l'incluraient dans la valeur lue.
# =============================================================================

# Dossier contenant les donnees brutes (raw) en entree.
INDUSENSE_DATA_DIR=data/raw
# Dossier des donnees "gold" (donnees nettoyees/preparees, pretes a l'emploi).
INDUSENSE_GOLD_DIR=data/gold
# Dossier ou sont stockes les modeles entraines (fichiers .joblib, metadonnees).
INDUSENSE_MODEL_DIR=artifacts/models
# Graine aleatoire fixe : garantit des resultats reproductibles d'une execution a l'autre.
INDUSENSE_RANDOM_SEED=42
# Nom de la colonne CIBLE a predire (ici "panne" : 1 = panne, 0 = pas de panne).
INDUSENSE_TARGET_COL=panne
# Fenetre temporelle (en heures) pour rattacher un incident a une panne.
INDUSENSE_INCIDENT_WINDOW_HOURS=24
